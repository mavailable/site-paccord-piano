# Copier en .env et remplir les valeurs
SITE_URL=https://paccord-piano.fr

# Web3Forms (formulaire de contact) -- https://web3forms.com/
# IMPORTANT : prefixe PUBLIC_ requis pour l'acces cote client (Astro)
PUBLIC_WEB3FORMS_KEY=votre-cle-web3forms

# OpenRouteService (calculateur de tarif par code postal) -- https://openrouteservice.org/
# IMPORTANT : prefixe PUBLIC_ requis pour l'acces cote client (Astro)
PUBLIC_ORS_API_KEY=votre-cle-openrouteservice

# Umami Analytics (cree en wf-10 lors du deploiement)
UMAMI_WEBSITE_ID=

# CMS maison
CMS_PASSWORD=your-cms-password
CMS_SESSION_SECRET=random-string-32-chars-minimum
CMS_REPO=mavailable/site-paccord-piano
CMS_BRANCH=dev
GITHUB_TOKEN=ghp_your_github_token
