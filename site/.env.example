# Copier en .env et remplir les valeurs
SITE_URL=https://paccord-piano.fr

# Web3Forms (formulaire de contact) — https://web3forms.com/
# IMPORTANT : préfixe PUBLIC_ requis pour l'accès côté client (Astro)
PUBLIC_WEB3FORMS_KEY=votre-cle-web3forms

# OpenRouteService (calculateur de tarif par code postal) — https://openrouteservice.org/
# IMPORTANT : préfixe PUBLIC_ requis pour l'accès côté client (Astro)
PUBLIC_ORS_API_KEY=votre-cle-openrouteservice

# Umami Analytics (créé en wf-10 lors du déploiement)
UMAMI_WEBSITE_ID=

# Keystatic Cloud (pour le mode CMS — créé lors du setup Keystatic)
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
