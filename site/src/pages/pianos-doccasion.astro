---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import { getPianos } from '@data/content';
import { getBreadcrumbSchema } from '@data/schemas';

const title = "Pianos d'occasion révisés à Chartres | P'Accord Piano";
const description = "Pianos droits d'occasion entièrement restaurés, garantis 5 ans, banquette incluse, livraison offerte à 80 km. Sur rendez-vous. Dès 1 200 €.";
const canonical = "https://paccord-piano.fr/pianos-doccasion";

// Schema.org Breadcrumb centralise — doctrine C1
// Note : Product/ItemList inline preserves (schemaItemList ci-dessous)
// car specific a cette page commercante, hors scope C1 minimal.
const schemaBreadcrumb = getBreadcrumbSchema([
  { name: 'Accueil', url: 'https://paccord-piano.fr' },
  { name: "Pianos d'occasion", url: '/pianos-doccasion' },
]);

const pianos = getPianos().filter(p => p.disponible);

const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Pianos d'occasion révisés — P'Accord Piano",
  "description": "Sélection de pianos droits d'occasion entièrement restaurés, garantis 5 ans, banquette incluse.",
  "numberOfItems": pianos.length,
  "itemListElement": pianos.map((piano, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "Product",
      "name": `Piano droit ${piano.marque} ${piano.modele}`,
      "description": `Piano droit ${piano.hauteur}, ${piano.origine} (${piano.annee}). Entièrement révisé.`,
      "brand": { "@type": "Brand", "name": piano.marque },
      "offers": {
        "@type": "Offer",
        "price": String(piano.prix),
        "priceCurrency": "EUR",
        "availability": "https://schema.org/InStock",
        "seller": { "@id": "https://paccord-piano.fr/#business" }
      }
    }
  }))
};

const engagements = [
  { icon: "shield", label: "Garantie 5 ans", detail: "Sur toutes les interventions réalisées" },
  { icon: "gift", label: "Banquette incluse", detail: "Assortie avec chaque piano" },
  { icon: "truck", label: "Livraison offerte", detail: "En rez-de-chaussée dans un rayon de 80 km" },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage="https://paccord-piano.fr/images/og-pianos.jpg"
  schema={[schemaBreadcrumb, schemaItemList]}
>
  <Header slot="header" />

  <!-- Hero page pianos -->
  <section class="bg-primary-950 pt-16 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <!-- Breadcrumb -->
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 font-body text-sm text-neutral-500">
          <li><a href="/" class="hover:text-accent-400 transition-colors">Accueil</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li aria-current="page" class="text-neutral-300">Pianos d'occasion</li>
        </ol>
      </nav>

      <h1 class="font-heading font-bold text-white text-4xl md:text-5xl mb-4">
        Pianos d'occasion révisés
      </h1>
      <p class="font-body text-neutral-400 text-lg md:text-xl max-w-2xl mb-8">
        Une sélection de pianos droits entièrement restaurés, garantis 5 ans, avec banquette et livraison offerte. Sur rendez-vous uniquement.
      </p>

      <!-- Introduction -->
      <div class="bg-primary-900 rounded-xl p-6 border border-primary-800/60 max-w-3xl">
        <p class="font-body text-neutral-300 leading-relaxed">
          Chaque piano proposé par P'Accord Piano a fait l'objet d'une révision complète : accord, harmonisation, réglage des mécaniques, remplacement des pièces défectueuses et polissage du meuble. Vous achetez un instrument remis à neuf, contrôlé par un technicien BMA, avec la garantie et la tranquillité d'esprit qui vont avec.
        </p>
      </div>
    </div>
  </section>

  <!-- Engagements -->
  <section class="bg-primary-900 border-y border-primary-800/40 py-8">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <dl class="grid grid-cols-1 sm:grid-cols-3 gap-6 divide-y sm:divide-y-0 sm:divide-x divide-primary-800/60">
        {engagements.map(e => (
          <div class="flex items-center gap-4 sm:justify-center sm:flex-col sm:text-center pt-4 sm:pt-0 first:pt-0">
            <div class="w-10 h-10 bg-accent-500/15 rounded-lg flex items-center justify-center flex-shrink-0">
              {e.icon === 'shield' && (
                <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              )}
              {e.icon === 'gift' && (
                <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>
                </svg>
              )}
              {e.icon === 'truck' && (
                <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
                </svg>
              )}
            </div>
            <div>
              <dt class="font-body font-semibold text-white text-sm">{e.label}</dt>
              <dd class="font-body text-xs text-neutral-400 mt-0.5">{e.detail}</dd>
            </div>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- Catalogue pianos -->
  <section class="bg-neutral-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {pianos.map((piano, index) => (
          <article
            class="bg-white rounded-xl overflow-hidden border border-neutral-200 shadow-sm hover:shadow-md transition-shadow flex flex-col"
            itemscope itemtype="https://schema.org/Product"
            aria-label={`${piano.marque} ${piano.modele}`}
          >
            <!-- Photo du piano ou placeholder -->
            <div class="aspect-[16/10] bg-primary-100 flex flex-col items-center justify-center text-primary-500 relative overflow-hidden">
              {piano.image ? (
                <img
                  src={piano.image}
                  alt={piano.imageAlt}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <>
                  <svg class="w-16 h-16 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
                  </svg>
                  <p class="font-body text-xs text-primary-400 mt-2">Photo à venir</p>
                </>
              )}
              <!-- Prix en overlay -->
              <div class="absolute top-4 right-4">
                <span class="font-body font-bold text-sm bg-accent-500 text-neutral-900 px-3 py-1.5 rounded-full">
                  {piano.prix.toLocaleString('fr-FR')} €
                </span>
              </div>
              <!-- Numéro du piano -->
              <div class="absolute bottom-4 left-4">
                <span class="font-body text-xs text-primary-400 bg-primary-50 px-2 py-1 rounded">
                  Piano #{index + 1}
                </span>
              </div>
            </div>

            <!-- Infos -->
            <div class="p-6 flex flex-col flex-1">
              <div class="flex items-start justify-between mb-3">
                <div>
                  <h2 class="font-heading font-bold text-primary-950 text-xl" itemprop="name" data-cms-field={`pianos.${piano.slug}.marque`} data-cms-type="text">
                    {piano.marque} {piano.modele}
                  </h2>
                  <p class="font-body text-sm text-neutral-500 mt-0.5">
                    {piano.annee} · {piano.origine} · {piano.hauteur}
                  </p>
                </div>
              </div>

              <p class="font-body text-neutral-700 text-sm leading-relaxed flex-1 mb-5" itemprop="description" data-cms-field={`pianos.${piano.slug}.description`} data-cms-type="text">
                {piano.description}
              </p>

              <!-- Caractéristiques -->
              <div class="grid grid-cols-3 gap-3 mb-5 py-4 border-y border-neutral-100">
                <div class="text-center">
                  <p class="font-heading font-bold text-primary-900 text-lg">{piano.annee}</p>
                  <p class="font-body text-xs text-neutral-500">Année</p>
                </div>
                <div class="text-center border-x border-neutral-100">
                  <p class="font-heading font-bold text-primary-900 text-lg">{piano.hauteur}</p>
                  <p class="font-body text-xs text-neutral-500">Hauteur</p>
                </div>
                <div class="text-center">
                  <p class="font-heading font-bold text-primary-900 text-lg">5 ans</p>
                  <p class="font-body text-xs text-neutral-500">Garantie</p>
                </div>
              </div>

              <!-- Prix + CTA -->
              <div class="flex items-center justify-between">
                <div itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                  <meta itemprop="price" content={String(piano.prix)} />
                  <meta itemprop="priceCurrency" content="EUR" />
                  <meta itemprop="availability" content="https://schema.org/InStock" />
                  <p class="font-heading font-bold text-primary-950 text-2xl">
                    {piano.prix.toLocaleString('fr-FR')} €
                  </p>
                  <p class="font-body text-xs text-neutral-500">Banquette incluse</p>
                </div>
                <a
                  href="/contact"
                  class="inline-flex items-center gap-2 bg-accent-500 text-neutral-900 font-body font-semibold text-sm px-5 py-3 rounded hover:bg-accent-400 transition-colors min-h-[44px]"
                >
                  Me renseigner
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Note bas de catalogue -->
      <div class="mt-12 bg-primary-950 rounded-xl p-6 md:p-8 text-center max-w-2xl mx-auto">
        <p class="font-body text-neutral-300 text-sm leading-relaxed mb-4">
          Les pianos sont visibles sur rendez-vous uniquement. Pour prendre rendez-vous ou obtenir plus d'informations sur un instrument en particulier, contactez Simon directement.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 bg-accent-500 text-neutral-900 font-body font-semibold px-6 py-3.5 rounded hover:bg-accent-400 transition-colors min-h-[48px]"
        >
          Prendre rendez-vous
        </a>
      </div>
    </div>
  </section>

  <CTABanner />
  <Footer slot="footer" />

</BaseLayout>
