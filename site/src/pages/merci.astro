---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

const title = "Demande reçue — Merci ! | P'Accord Piano";
const description = "Votre demande de réservation a bien été reçue. Simon PACOR vous répondra dans les 48h.";
const canonical = "https://paccord-piano.fr/merci";
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  noindex={true}
>
  <Header slot="header" />

  <section class="bg-neutral-50 min-h-[70vh] flex items-center py-20">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">

      <!-- Icône succès -->
      <div class="w-20 h-20 bg-accent-500/15 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
      </div>

      <h1 class="font-heading font-bold text-primary-950 text-3xl md:text-4xl mb-5">
        Merci pour votre message&nbsp;!
      </h1>

      <p class="font-body text-neutral-700 text-lg leading-relaxed mb-3">
        Simon a bien reçu votre demande de rendez-vous et vous recontactera sous 48h pour confirmer la date et l'heure de son passage.
      </p>

      <p class="font-body text-neutral-500 mb-10">
        En attendant, si vous avez une question urgente, vous pouvez le joindre directement au
        <a href="tel:0622267783" class="font-semibold text-primary-900 hover:text-accent-600 transition-colors">06.22.26.77.83</a>.
      </p>

      <!-- CTAs secondaires -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary-950 text-white font-body font-semibold px-6 py-3.5 rounded hover:bg-primary-800 transition-colors min-h-[48px]"
        >
          Retourner à l'accueil
        </a>
        <a
          href="/pianos-doccasion"
          class="inline-flex items-center justify-center gap-2 border border-neutral-300 text-neutral-700 font-body font-semibold px-6 py-3.5 rounded hover:border-neutral-400 hover:text-primary-900 transition-colors min-h-[48px]"
        >
          Voir les pianos d'occasion
        </a>
      </div>

      <!-- Laisser un avis Google -->
      <div class="mt-12 pt-8 border-t border-neutral-200">
        <p class="font-body text-sm text-neutral-500 mb-3">
          Vous êtes déjà client ? Votre avis Google aide Simon à se faire connaître&nbsp;:
        </p>
        <a
          href="https://search.google.com/local/writereview?placeid=ChIJw2vlMiJe5EcRKTxUi3EbORI"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 font-body text-sm font-medium text-neutral-600 hover:text-primary-900 transition-colors"
          aria-label="Laisser un avis sur Google pour P'Accord Piano"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Laisser un avis Google
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
