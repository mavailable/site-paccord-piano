---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

const title = "Mentions légales | P'Accord Piano";
const description = "Mentions légales du site paccord-piano.fr — P'Accord Piano, technicien accordeur de pianos à Chartres (28), Eure-et-Loir.";
const canonical = "https://paccord-piano.fr/mentions-legales";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://paccord-piano.fr" },
    { "@type": "ListItem", "position": 2, "name": "Mentions légales", "item": "https://paccord-piano.fr/mentions-legales" }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical} noindex={true} schema={schemaBreadcrumb}>
  <Header slot="header" />

  <!-- Hero -->
  <section class="bg-primary-950 pt-16 pb-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="mb-6">
        <ol class="flex items-center gap-2 font-body text-sm text-neutral-500">
          <li><a href="/" class="hover:text-accent-400 transition-colors">Accueil</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li aria-current="page" class="text-neutral-300">Mentions légales</li>
        </ol>
      </nav>
      <h1 class="font-heading font-bold text-white text-3xl md:text-4xl">Mentions légales</h1>
      <p class="font-body text-neutral-500 text-sm mt-2">Dernière mise à jour : mars 2026</p>
    </div>
  </section>

  <!-- Contenu -->
  <section class="bg-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="prose-legal">

        <!-- 1. Éditeur du site -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            1. Éditeur du site
          </h2>
          <div class="font-body text-neutral-700 space-y-1 text-sm leading-relaxed">
            <p><strong class="text-primary-900">Raison sociale :</strong> P'Accord Piano</p>
            <p><strong class="text-primary-900">Forme juridique :</strong> Entreprise individuelle</p>
            <p><strong class="text-primary-900">Numéro RCS :</strong> 983 922 030 RCS Chartres</p>
            <p><strong class="text-primary-900">Siège social :</strong> 3 Rue du Château d'eau, 28190 Mittainvilliers-Vérigny</p>
            <p><strong class="text-primary-900">Téléphone :</strong> <a href="tel:0622267783" class="text-accent-600 hover:underline">06.22.26.77.83</a></p>
            <p><strong class="text-primary-900">Email :</strong> <a href="mailto:paccord.piano@gmail.com" class="text-accent-600 hover:underline">paccord.piano@gmail.com</a></p>
            <p><strong class="text-primary-900">TVA :</strong> Non applicable — article 293 B du CGI</p>
          </div>
        </div>

        <!-- 2. Directeur de publication -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            2. Directeur de la publication
          </h2>
          <p class="font-body text-neutral-700 text-sm">
            Simon PACOR, en qualité de gérant de P'Accord Piano.
          </p>
        </div>

        <!-- 3. Hébergeur -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            3. Hébergeur
          </h2>
          <div class="font-body text-neutral-700 text-sm space-y-1">
            <p><strong class="text-primary-900">Société :</strong> Cloudflare, Inc.</p>
            <p><strong class="text-primary-900">Adresse :</strong> 101 Townsend St, San Francisco, CA 94107, États-Unis</p>
            <p><strong class="text-primary-900">Téléphone :</strong> +1 (650) 319-8930</p>
            <p><strong class="text-primary-900">Site web :</strong> <a href="https://www.cloudflare.com" target="_blank" rel="noopener noreferrer" class="text-accent-600 hover:underline">www.cloudflare.com</a></p>
          </div>
        </div>

        <!-- 4. Propriété intellectuelle -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            4. Propriété intellectuelle
          </h2>
          <p class="font-body text-neutral-700 text-sm leading-relaxed">
            L'ensemble des éléments constituant le site paccord-piano.fr (textes, graphismes, logotypes, photographies, illustrations, sons) est la propriété exclusive de P'Accord Piano ou de ses partenaires. Toute reproduction, représentation, modification, publication ou adaptation de tout ou partie des éléments du site, quel que soit le moyen ou le procédé utilisé, est interdite sauf autorisation écrite préalable de P'Accord Piano.
          </p>
        </div>

        <!-- 5. Crédits -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            5. Crédits
          </h2>
          <div class="font-body text-neutral-700 text-sm space-y-1">
            <p><strong class="text-primary-900">Conception et réalisation :</strong> Marc Muller — <a href="mailto:marc@muller.im" class="text-accent-600 hover:underline">marc@muller.im</a></p>
            <p><strong class="text-primary-900">Photographies :</strong> Simon PACOR / P'Accord Piano</p>
            <p><strong class="text-primary-900">Technologie :</strong> Astro, Tailwind CSS, Cloudflare Pages</p>
          </div>
        </div>

        <!-- 6. Liens hypertextes -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            6. Liens hypertextes
          </h2>
          <p class="font-body text-neutral-700 text-sm leading-relaxed">
            Le site paccord-piano.fr peut contenir des liens vers des sites tiers. P'Accord Piano n'exerce aucun contrôle sur ces sites et décline toute responsabilité quant à leur contenu ou leur disponibilité.
          </p>
        </div>

        <!-- 7. Responsabilité -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            7. Limitation de responsabilité
          </h2>
          <p class="font-body text-neutral-700 text-sm leading-relaxed">
            Les informations contenues sur ce site sont fournies à titre indicatif. P'Accord Piano s'efforce de tenir ces informations à jour et exactes, mais ne peut garantir l'exactitude, la complétude ou l'actualité des informations diffusées. P'Accord Piano décline toute responsabilité pour tout préjudice direct ou indirect résultant de l'utilisation du site.
          </p>
        </div>

        <!-- 8. Droit applicable -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            8. Droit applicable et juridiction
          </h2>
          <p class="font-body text-neutral-700 text-sm leading-relaxed">
            Le présent site et les présentes mentions légales sont régis par le droit français. En cas de litige, et à défaut de résolution amiable, les tribunaux compétents du ressort de Chartres seront seuls compétents.
          </p>
        </div>

        <!-- 9. Données personnelles -->
        <div class="mb-10">
          <h2 class="font-heading font-bold text-primary-950 text-xl mb-4 pb-2 border-b border-neutral-200">
            9. Données personnelles
          </h2>
          <p class="font-body text-neutral-700 text-sm leading-relaxed">
            Pour toute information sur la collecte et le traitement de vos données personnelles, consultez notre
            <a href="/politique-de-confidentialite" class="text-accent-600 hover:underline font-medium">politique de confidentialité</a>.
          </p>
        </div>

      </div>

      <!-- Liens bas de page -->
      <div class="mt-12 pt-6 border-t border-neutral-200 flex flex-wrap gap-4">
        <a href="/" class="font-body text-sm text-neutral-500 hover:text-primary-900 transition-colors">← Retour à l'accueil</a>
        <a href="/politique-de-confidentialite" class="font-body text-sm text-neutral-500 hover:text-primary-900 transition-colors">Politique de confidentialité</a>
        <a href="/cgv" class="font-body text-sm text-neutral-500 hover:text-primary-900 transition-colors">CGV</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
