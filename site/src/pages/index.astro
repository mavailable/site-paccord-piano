---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import Hero from '@components/sections/Hero.astro';
import SocialProof from '@components/sections/SocialProof.astro';
import About from '@components/sections/About.astro';
import Services from '@components/sections/Services.astro';
import Testimonials from '@components/sections/Testimonials.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import {
  getProfessionalServiceSchema,
  getPersonSchema,
  getWebsiteSchema,
  getFAQPageSchema,
  getBreadcrumbSchema,
  getSpeakableSchema,
} from '@data/schemas';

const title = "Accordeur de piano à Chartres | Simon PACOR — P'Accord Piano";
const description = "Technicien accordeur réparateur de pianos, diplômé BMA ITEMM. À domicile à Chartres et 100 km alentours. À partir de 90 €. Devis gratuit.";
const canonical = "https://paccord-piano.fr";

// Schemas centralises — doctrine C1 wf-00-cms §7
const schemaProfessionalService = getProfessionalServiceSchema();
const schemaPerson = getPersonSchema();
const schemaWebsite = getWebsiteSchema();
const schemaFAQ = getFAQPageSchema();
const schemaBreadcrumb = getBreadcrumbSchema([{ name: 'Accueil', url: canonical }]);
const schemaSpeakable = getSpeakableSchema(title, description, canonical);

---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  schema={[schemaProfessionalService, schemaPerson, schemaWebsite, schemaFAQ, schemaBreadcrumb, schemaSpeakable]}
>
  <Header slot="header" />

  <Hero />
  <SocialProof />
  <About />
  <Services />
  <Testimonials />
  <FAQ />
  <CTABanner />

  <Footer slot="footer" />
</BaseLayout>
