---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import ContactForm from '@components/forms/ContactForm.astro';

const title = "Réserver un accord de piano | P'Accord Piano — Chartres";
const description = "Calculez votre tarif par code postal et réservez en ligne. Réponse sous 48h. Déplacements en Eure-et-Loir, Île-de-France et alentours.";
const canonical = "https://paccord-piano.fr/contact";

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://paccord-piano.fr" },
    { "@type": "ListItem", "position": 2, "name": "Réserver un accord", "item": "https://paccord-piano.fr/contact" }
  ]
};
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schemaBreadcrumb}>
  <Header slot="header" />

  <!-- Hero page contact -->
  <section class="bg-primary-950 pt-16 pb-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 font-body text-sm text-neutral-500">
          <li><a href="/" class="hover:text-accent-400 transition-colors">Accueil</a></li>
          <li aria-hidden="true"><span>/</span></li>
          <li aria-current="page" class="text-neutral-300">Contact & Réservation</li>
        </ol>
      </nav>
      <h1 class="font-heading font-bold text-white text-4xl md:text-5xl mb-4">
        Réservez votre accord
      </h1>
      <p class="font-body text-neutral-400 text-lg md:text-xl max-w-2xl">
        Entrez votre code postal pour connaître votre tarif et réservez directement en ligne. Simon vous recontacte sous 48h.
      </p>
    </div>
  </section>

  <section class="bg-neutral-50 py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Formulaire (2/3) -->
        <main class="lg:col-span-2 bg-white rounded-xl p-6 md:p-10 border border-neutral-200 shadow-sm">
          <ContactForm />
        </main>

        <!-- Sidebar (1/3) -->
        <aside>
          <div class="bg-primary-950 rounded-xl p-6 text-white mb-6">
            <h2 class="font-heading font-semibold text-lg mb-5">Contact direct</h2>
            <address class="not-italic space-y-4">
              <a href="tel:0622267783" data-track="phone-click" class="flex items-center gap-3 font-body text-sm text-neutral-300 hover:text-accent-400 transition-colors group">
                <span class="w-9 h-9 bg-primary-800 group-hover:bg-accent-500/20 rounded flex items-center justify-center flex-shrink-0 transition-colors">
                  <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </span>
                <span class="font-semibold text-white">06.22.26.77.83</span>
              </a>
              <a href="mailto:paccord.piano@gmail.com" data-track="email-click" class="flex items-center gap-3 font-body text-sm text-neutral-300 hover:text-accent-400 transition-colors group">
                <span class="w-9 h-9 bg-primary-800 group-hover:bg-accent-500/20 rounded flex items-center justify-center flex-shrink-0 transition-colors">
                  <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </span>
                paccord.piano@gmail.com
              </a>
              <div class="flex items-start gap-3 font-body text-sm text-neutral-400">
                <span class="w-9 h-9 bg-primary-800 rounded flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </span>
                <span>Intervient dans un rayon de 100 km autour de Chartres — Eure-et-Loir, Yvelines, Eure, Orne, Paris.</span>
              </div>
            </address>
          </div>

          <div class="bg-white rounded-xl p-5 border border-neutral-200 mb-6">
            <h2 class="font-heading font-semibold text-primary-900 text-base mb-3">Disponibilités</h2>
            <p class="font-body text-sm text-neutral-600 mb-3">Sur rendez-vous uniquement.</p>
            <div class="space-y-1.5">
              {[['Lundi – Vendredi','Matin & après-midi'],['Samedi','Matin & après-midi'],['Dimanche','Fermé']].map(([j,h]) => (
                <div class="flex justify-between font-body text-sm">
                  <span class="text-neutral-700">{j}</span>
                  <span class="text-neutral-500">{h}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="space-y-3">
            {[
              ['Réponse sous 48h','Simon vous recontacte rapidement'],
              ['Tarif tout compris','Déplacement inclus, aucun frais caché'],
              ['Sans engagement','Aucun acompte demandé à la réservation'],
            ].map(([titre, detail]) => (
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-accent-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                <div>
                  <p class="font-body text-sm font-semibold text-primary-900">{titre}</p>
                  <p class="font-body text-xs text-neutral-500">{detail}</p>
                </div>
              </div>
            ))}
          </div>
        </aside>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
