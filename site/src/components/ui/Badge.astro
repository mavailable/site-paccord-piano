---
interface Props {
  variant?: 'accent' | 'primary' | 'neutral' | 'success';
  size?: 'sm' | 'md';
  class?: string;
}

const {
  variant = 'primary',
  size = 'sm',
  class: className = '',
} = Astro.props;

const variantClasses = {
  accent:  'bg-accent-500/15 text-accent-400 border border-accent-500/30',
  primary: 'bg-primary-100 text-primary-800 border border-primary-200',
  neutral: 'bg-neutral-100 text-neutral-700 border border-neutral-200',
  success: 'bg-green-100 text-green-800 border border-green-200',
};

const sizeClasses = {
  sm: 'text-xs px-2.5 py-1',
  md: 'text-sm px-3 py-1.5',
};

const classes = `inline-flex items-center gap-1.5 font-body font-medium rounded-full ${variantClasses[variant]} ${sizeClasses[size]} ${className}`;
---

<span class={classes}>
  <slot />
</span>
