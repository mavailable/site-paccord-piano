---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  target?: string;
  rel?: string;
  'aria-label'?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  target,
  rel,
  'aria-label': ariaLabel,
} = Astro.props;

const sizeClasses = {
  sm: 'text-sm px-4 py-2 min-h-[36px]',
  md: 'text-base px-6 py-3 min-h-[48px]',
  lg: 'text-lg px-8 py-4 min-h-[52px]',
};

const variantClasses = {
  // ⚠️ accent-500 (#f9b233) NE JAMAIS avec text-white (ratio 1.84 ❌)
  // Toujours text-neutral-900 sur fond accent-500
  primary:   'bg-accent-500 text-neutral-900 hover:bg-accent-400 font-semibold',
  secondary: 'bg-primary-900 text-white hover:bg-primary-800 font-semibold',
  outline:   'border-2 border-current text-white hover:bg-white/10 font-medium',
  ghost:     'text-white hover:bg-white/10 font-medium',
};

const baseClasses = 'inline-flex items-center justify-center gap-2 rounded transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500';

const classes = `${baseClasses} ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} aria-label={ariaLabel}>
    <slot />
  </button>
)}
