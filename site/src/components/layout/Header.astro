---
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();

const nav = [
  { label: "L'Artisan",      href: '/#artisan' },
  { label: 'Services',       href: '/#services' },
  { label: 'Témoignages',    href: '/#temoignages' },
  { label: 'FAQ',            href: '/#faq' },
  { label: "Pianos d'occasion", href: '/pianos-doccasion' },
];
---

<header class="sticky top-0 z-50 bg-primary-950 border-b border-primary-800/60">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-18 py-3">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 flex-shrink-0" aria-label={`${siteInfo.name} — Accueil`}>
      <img
        src="/images/logos/Logo_pacorpiano_complet_blanc.svg"
        alt={`Logo ${siteInfo.name}`}
        class="h-10 w-auto"
        loading="eager"
      />
    </a>

    <!-- Nav desktop -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Navigation principale">
      {nav.map(link => (
        <a
          href={link.href}
          class="font-body text-sm text-neutral-300 hover:text-accent-400 px-3 py-2 rounded transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA desktop + tel -->
    <div class="hidden lg:flex items-center gap-4">
      <a
        href={`tel:${siteInfo.phone.replace(/\./g, '')}`}
        class="font-body text-sm text-neutral-300 hover:text-white transition-colors flex items-center gap-1.5"
        aria-label={`Appeler ${siteInfo.phone}`}
      >
        <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        {siteInfo.phone}
      </a>
      <a
        href="/contact"
        class="font-body font-semibold text-sm bg-accent-500 text-neutral-900 px-4 py-2.5 rounded hover:bg-accent-400 transition-colors min-h-[44px] flex items-center"
      >
        Réserver
      </a>
    </div>

    <!-- Tel mobile (visible sur mobile) -->
    <div class="flex lg:hidden items-center gap-3">
      <a
        href={`tel:${siteInfo.phone.replace(/\./g, '')}`}
        class="text-accent-500 hover:text-accent-400 transition-colors"
        aria-label={`Appeler ${siteInfo.phone}`}
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
      </a>
      <!-- Hamburger -->
      <button
        id="mobile-menu-btn"
        class="text-neutral-300 hover:text-white p-1.5 rounded transition-colors"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Ouvrir le menu"
      >
        <svg id="icon-menu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-primary-950 border-t border-primary-800/60 px-4 pb-4"
    role="navigation"
    aria-label="Menu mobile"
  >
    <nav class="flex flex-col gap-1 pt-3">
      {nav.map(link => (
        <a
          href={link.href}
          class="font-body text-base text-neutral-300 hover:text-accent-400 hover:bg-primary-900 px-3 py-2.5 rounded transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-3 font-body font-semibold text-base bg-accent-500 text-neutral-900 px-4 py-3 rounded hover:bg-accent-400 transition-colors text-center"
      >
        Réserver un accord
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconMenu?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Ouvrir le menu' : 'Fermer le menu');
  });

  // Fermer avec Echap
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
      btn?.setAttribute('aria-label', 'Ouvrir le menu');
      btn?.focus();
    }
  });

  // Fermer au clic sur un lien
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      btn?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
