---
import { getSiteInfo } from '@data/content';
const siteInfo = getSiteInfo();

const currentYear = new Date().getFullYear();

const services = [
  "Accord de piano",
  "Harmonisation",
  "Réglage des mécaniques",
  "Réparations & Restaurations",
  "Conseil à l'achat",
];
---

<footer class="bg-primary-950 border-t border-primary-800/60" aria-label="Pied de page">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">

      <!-- Col 1 : identité -->
      <div>
        <a href="/" aria-label={`${siteInfo.name} — Accueil`}>
          <img
            src="/images/logos/Logo_pacorpiano_complet_blanc.svg"
            alt={`Logo ${siteInfo.name}`}
            class="h-10 w-auto mb-4"
            loading="lazy"
          />
        </a>
        <p class="font-body text-sm text-neutral-400 leading-relaxed mb-6 max-w-xs">
          Technicien accordeur réparateur de pianos, diplômé BMA ITEMM. Intervient à domicile dans un rayon de 100 km autour de Chartres.
        </p>
        <!-- Réseaux sociaux -->
        <div class="flex gap-3">
          <a
            href={siteInfo.facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-primary-800 hover:bg-primary-700 rounded flex items-center justify-center transition-colors"
            aria-label="Facebook P'Accord Piano"
          >
            <img src="/images/logos/Facebook_logo_blanc.svg" alt="" class="w-4 h-4" aria-hidden="true" />
          </a>
          <a
            href={siteInfo.googleBusinessUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 bg-primary-800 hover:bg-primary-700 rounded flex items-center justify-center transition-colors"
            aria-label="Google Business P'Accord Piano"
          >
            <img src="/images/logos/Google_logo_blanc.svg" alt="" class="w-4 h-4" aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Col 2 : services -->
      <div>
        <h2 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Services</h2>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href="/#services" class="font-body text-sm text-neutral-400 hover:text-accent-400 transition-colors">
                {s}
              </a>
            </li>
          ))}
          <li>
            <a href="/pianos-doccasion" class="font-body text-sm text-neutral-400 hover:text-accent-400 transition-colors">
              Pianos d'occasion
            </a>
          </li>
        </ul>
      </div>

      <!-- Col 3 : coordonnées -->
      <div>
        <h2 class="font-heading font-semibold text-white text-sm uppercase tracking-wider mb-4">Contact</h2>
        <address class="not-italic space-y-3">
          <p class="font-body text-sm text-neutral-400 flex items-start gap-2">
            <svg class="w-4 h-4 text-accent-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>{siteInfo.address}<br />{siteInfo.postalCode} {siteInfo.city}</span>
          </p>
          <p class="font-body text-sm">
            <a
              href={`tel:${siteInfo.phone.replace(/\./g, '')}`}
              class="text-neutral-400 hover:text-accent-400 transition-colors flex items-center gap-2"
            >
              <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {siteInfo.phone}
            </a>
          </p>
          <p class="font-body text-sm">
            <a
              href={`mailto:${siteInfo.email}`}
              class="text-neutral-400 hover:text-accent-400 transition-colors flex items-center gap-2"
            >
              <svg class="w-4 h-4 text-accent-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {siteInfo.email}
            </a>
          </p>
          <p class="font-body text-sm text-neutral-500">
            Sur rendez-vous · Lundi–Samedi
          </p>
        </address>
      </div>

    </div>

    <!-- Barre bas -->
    <div class="mt-12 pt-6 border-t border-primary-800/60 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="font-body text-xs text-neutral-600 order-2 sm:order-1">
        © {currentYear} {siteInfo.name} · Tous droits réservés
      </p>
      <nav class="flex flex-wrap justify-center gap-4 order-1 sm:order-2" aria-label="Liens légaux">
        <a href="/mentions-legales" class="font-body text-xs text-neutral-600 hover:text-neutral-400 transition-colors">Mentions légales</a>
        <a href="/politique-de-confidentialite" class="font-body text-xs text-neutral-600 hover:text-neutral-400 transition-colors">Politique de confidentialité</a>
        <a href="/cgv" class="font-body text-xs text-neutral-600 hover:text-neutral-400 transition-colors">CGV</a>
      </nav>
    </div>

  </div>
</footer>
