---
import { getAbout } from '@data/content';

const about = getAbout();
---

<!-- Bande de stats — pont visuel entre Hero (sombre) et About (ivoire) -->
<section
  class="bg-primary-900 border-y border-primary-800/40"
  aria-label="Chiffres clés"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <dl class="grid grid-cols-3 gap-4 sm:gap-8 divide-x divide-primary-800/60">
      {about.stats.map((stat) => (
        <div class="flex flex-col items-center text-center px-2">
          <dt class="font-heading font-bold text-3xl sm:text-4xl text-accent-400 leading-none mb-2">
            {stat.value}
          </dt>
          <dd class="font-body text-xs sm:text-sm text-neutral-400 leading-tight">
            {stat.label}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
