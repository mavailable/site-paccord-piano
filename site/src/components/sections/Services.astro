---
import { getServices } from '@data/content';

const services = getServices();

// Service principal (accord) + services secondaires
const mainService = services.find(s => s.slug === 'accord');
const otherServices = services.filter(s => s.slug !== 'accord');
---

<!-- Services — fond noir piano, cards asymétriques -->
<section id="services" class="bg-primary-950 py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">

    <!-- En-tête -->
    <div class="mb-14 max-w-2xl">
      <span class="font-body text-sm font-semibold text-accent-500 uppercase tracking-widest mb-2 block">
        Prestations
      </span>
      <h2 class="font-heading font-bold text-white text-3xl md:text-4xl mb-4">
        Des prestations sur mesure pour votre piano
      </h2>
      <p class="font-body text-neutral-400 text-lg leading-relaxed">
        De l'accord d'entretien à la restauration complète — chaque intervention est adaptée à votre instrument et à votre jeu.
      </p>
    </div>

    <!-- Card principale : L'Accord (service avec prix fixe) -->
    {mainService && (
      <div class="mb-6 bg-primary-900 rounded-2xl overflow-hidden border border-primary-800/60 grid grid-cols-1 md:grid-cols-2">
        <!-- Image -->
        <div class="relative aspect-[16/9] md:aspect-auto">
          <picture>
            <source media="(max-width: 478px)" srcset="/images/accords/360_accords.webp" />
            <source media="(max-width: 767px)" srcset="/images/accords/478_accords.webp" />
            <img
              src="/images/accords/1280_accords.webp"
              alt={mainService.imageAlt}
              class="w-full h-full object-cover object-center"
              loading="lazy"
              width="640"
              height="480"
            />
          </picture>
          <!-- Badge prix flottant -->
          <div class="absolute top-4 left-4">
            <span class="font-body font-bold text-sm bg-accent-500 text-neutral-900 px-3 py-1.5 rounded-full" data-cms-field="services.accord.price" data-cms-type="text">
              {mainService.price}
            </span>
          </div>
        </div>
        <!-- Contenu -->
        <div class="p-8 md:p-10 flex flex-col justify-between">
          <div>
            <p class="font-body text-xs font-semibold text-accent-500 uppercase tracking-widest mb-3">
              Service principal
            </p>
            <h3 class="font-heading font-bold text-white text-2xl md:text-3xl mb-4" data-cms-field="services.accord.title" data-cms-type="text">
              {mainService.title}
            </h3>
            <p class="font-body text-neutral-400 leading-relaxed mb-3" data-cms-field="services.accord.description" data-cms-type="text">
              {mainService.description}
            </p>
            <p class="font-body text-sm text-neutral-500 italic" data-cms-field="services.accord.priceNote" data-cms-type="text">
              {mainService.priceNote}
            </p>
          </div>
          <div class="mt-8">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 bg-accent-500 text-neutral-900 font-body font-semibold px-6 py-3.5 rounded hover:bg-accent-400 transition-colors min-h-[48px]"
            >
              Calculer mon tarif
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Grille des 4 autres services -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-5">
      {otherServices.map((service) => (
        <article class="bg-primary-900 rounded-xl overflow-hidden border border-primary-800/60 flex flex-col hover:border-primary-700/80 transition-colors group">
          <!-- Image -->
          <div class="relative aspect-[16/10] overflow-hidden">
            <img
              src={service.image}
              alt={service.imageAlt}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
              loading="lazy"
              width="400"
              height="250"
              data-cms-field={`services.${service.slug}.image`} data-cms-type="image"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-primary-900/80 to-transparent"></div>
          </div>
          <!-- Contenu -->
          <div class="p-6 flex flex-col flex-1">
            <h3 class="font-heading font-semibold text-white text-lg mb-2" data-cms-field={`services.${service.slug}.title`} data-cms-type="text">
              {service.title}
            </h3>
            <p class="font-body text-neutral-400 text-sm leading-relaxed flex-1 mb-4" data-cms-field={`services.${service.slug}.shortDesc`} data-cms-type="text">
              {service.shortDesc}
            </p>
            <div class="flex items-center justify-between">
              <span class="font-body text-sm font-semibold text-accent-400" data-cms-field={`services.${service.slug}.price`} data-cms-type="text">
                {service.price}
              </span>
              <a
                href="/contact"
                class="font-body text-xs font-medium text-neutral-400 hover:text-accent-400 transition-colors flex items-center gap-1"
                aria-label={`Contacter pour ${service.title}`}
              >
                Me contacter
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- CTA bas de section -->
    <div class="mt-12 text-center">
      <p class="font-body text-neutral-500 text-sm mb-4">
        Devis gratuit pour toutes les prestations hors accord
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 border border-primary-700 text-neutral-300 font-body font-medium px-6 py-3 rounded hover:border-accent-500/40 hover:text-white transition-colors min-h-[48px]"
      >
        Demander un devis
      </a>
    </div>

  </div>
</section>
