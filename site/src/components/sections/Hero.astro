---
import { getHero, getSiteInfo } from '@data/content';

const hero = getHero();
const siteInfo = getSiteInfo();
---

<section
  id="accueil"
  class="relative min-h-[92vh] flex items-center bg-primary-950 overflow-hidden"
  aria-label="Accueil"
>
  <!-- Image de fond responsive -->
  <picture class="absolute inset-0 w-full h-full select-none" aria-hidden="true">
    <source media="(max-width: 478px)"  srcset="/images/hero/360_hero.webp" />
    <source media="(max-width: 767px)"  srcset="/images/hero/478_hero.webp" />
    <source media="(max-width: 991px)"  srcset="/images/hero/767_hero.webp" />
    <source media="(max-width: 1280px)" srcset="/images/hero/991_hero.webp" />
    <source media="(max-width: 1440px)" srcset="/images/hero/1280_hero.webp" />
    <source media="(min-width: 1441px)" srcset="/images/hero/1920_hero.webp" />
    <img
      src="/images/hero/1280_hero.webp"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
  </picture>

  <!-- Overlay gradient directionnel -->
  <div
    class="absolute inset-0"
    style="background: linear-gradient(105deg, rgba(5,5,5,0.92) 0%, rgba(5,5,5,0.75) 50%, rgba(5,5,5,0.35) 100%)"
    aria-hidden="true"
  ></div>

  <!-- Contenu -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 py-20">
    <div class="max-w-2xl">

      <!-- Badge réassurance -->
      <div class="inline-flex items-center gap-2 bg-accent-500/15 border border-accent-500/30 text-accent-400 font-body font-medium text-sm px-4 py-2 rounded-full mb-7">
        <span class="w-2 h-2 bg-accent-500 rounded-full inline-block shrink-0" aria-hidden="true"></span>
        <span data-cms-field="hero.badgeText" data-cms-type="text">{hero.badgeText}</span> · Frais de déplacement inclus
      </div>

      <!-- H1 — seul H1 de la page -->
      <h1 class="font-heading font-bold text-white text-4xl sm:text-5xl md:text-[3.25rem] leading-[1.15] mb-6" data-cms-field="hero.h1" data-cms-type="text">
        {hero.h1}
      </h1>

      <!-- Sous-titre -->
      <p class="font-body text-neutral-200 text-lg md:text-xl leading-relaxed mb-10 max-w-lg" data-cms-field="hero.subtitle" data-cms-type="text">
        {hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        <!-- CTA principal — JAMAIS text-white sur accent-500 -->
        <a
          href={hero.ctaUrl}
          class="inline-flex items-center justify-center gap-2 bg-accent-500 text-neutral-900 font-body font-semibold text-base px-8 py-4 rounded hover:bg-accent-400 transition-colors min-h-[52px] shadow-lg shadow-accent-500/20"
        >
          <span data-cms-field="hero.ctaLabel" data-cms-type="text">{hero.ctaLabel}</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <!-- CTA secondaire -->
        <a
          href={hero.ctaSecondaryUrl}
          class="inline-flex items-center justify-center gap-2 border-2 border-white/50 text-white font-body font-medium text-base px-8 py-4 rounded hover:border-white hover:bg-white/10 transition-colors min-h-[52px]"
        >
          <span data-cms-field="hero.ctaSecondaryLabel" data-cms-type="text">{hero.ctaSecondaryLabel}</span>
        </a>
      </div>

      <!-- Réassurance -->
      <p class="font-body text-neutral-500 text-sm">
        Réponse sous 48h · Tarif calculé selon votre code postal · Aucun engagement
      </p>

    </div>
  </div>

  <!-- Indicateur de scroll -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10" aria-hidden="true">
    <div class="flex flex-col items-center gap-1 text-neutral-500 text-xs font-body">
      <span class="animate-bounce">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </span>
    </div>
  </div>

</section>

<!-- Sticky CTA mobile (visible uniquement sur mobile) -->
<div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-primary-950/95 backdrop-blur-sm border-t border-primary-800/60 px-4 py-3 safe-area-inset-bottom">
  <a
    href="/contact"
    class="flex items-center justify-center gap-2 w-full bg-accent-500 text-neutral-900 font-body font-semibold text-base px-6 py-3.5 rounded min-h-[52px]"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
    </svg>
    Réserver mon accord
  </a>
</div>
