---
// CTA bannière — fond sombre avec accent, avant le footer
---

<section
  class="bg-primary-900 relative overflow-hidden"
  aria-label="Réserver un accord"
>
  <!-- Décoration : ligne accent en haut -->
  <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-accent-600 via-accent-500 to-accent-600" aria-hidden="true"></div>

  <!-- Décoration : cercles flous en arrière-plan -->
  <div class="absolute -left-24 -top-24 w-64 h-64 bg-accent-500/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
  <div class="absolute -right-24 -bottom-24 w-64 h-64 bg-accent-500/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 py-20 md:py-24 text-center">

    <h2 class="font-heading font-bold text-white text-3xl md:text-5xl leading-tight mb-5">
      Votre piano mérite le meilleur accord.
    </h2>

    <p class="font-body text-neutral-400 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
      Calculez votre tarif en quelques secondes et réservez directement en ligne.
    </p>

    <!-- CTA groupé dans un encadré -->
    <div class="inline-flex flex-col sm:flex-row gap-4 bg-primary-950/50 border border-primary-800/60 px-6 py-5 rounded-xl">
      <!-- CTA principal — JAMAIS text-white sur accent-500 -->
      <a
        href="/contact"
        data-track="cta"
        class="inline-flex items-center justify-center gap-2 bg-accent-500 text-neutral-900 font-body font-bold text-base px-8 py-4 rounded hover:bg-accent-400 transition-colors min-h-[52px] shadow-lg shadow-accent-500/25"
      >
        Je calcule mon tarif
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <a
        href="tel:0622267783"
        class="inline-flex items-center justify-center gap-2 border border-primary-700 text-neutral-300 font-body font-medium text-base px-6 py-4 rounded hover:border-neutral-500 hover:text-white transition-colors min-h-[52px]"
      >
        <svg class="w-4 h-4 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        06.22.26.77.83
      </a>
    </div>

    <!-- Réassurance -->
    <p class="mt-6 font-body text-neutral-600 text-xs">
      Réponse sous 48h · Déplacement inclus dans le tarif · Aucun engagement
    </p>

  </div>
</section>
